generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Vehiculo {
  idVehiculo       Int      @id @default(autoincrement()) @map("id_vehiculo")
  patente          String   @unique
  tipo             String
  capacidadBidones Int      @map("capacidad_bidones")
  idVendedor       Int      @map("id_vendedor")
  estado           String   @default("activo")
  motivoPausa      String?  @map("motivo_pausa")
  choferes         Chofer[]

  @@map("vehiculo")
}

model Chofer {
  idChofer    Int       @id @default(autoincrement()) @map("id_chofer")
  telefono    String?
  nombre      String    @default("Chofer")
  estado      String    @default("pendiente")
  idVehiculo  Int?      @map("id_vehiculo")
  idZona      Int?      @map("id_zona")
  alias       String?
  cbuCvu      String?   @map("cbu_cvu")
  clerkUserId String    @unique @map("clerk_user_id")
  cuilCuit    String?   @map("cuil_cuit")
  disponible  Boolean   @default(true)
  idVendedor  Int       @map("id_vendedor")
  nombreEmpresa String? @map("nombre_empresa")
  vehiculo    Vehiculo? @relation(fields: [idVehiculo], references: [idVehiculo])
  zona        zona?     @relation(fields: [idZona], references: [idZona])
  ruta        ruta[]
  pedidosAsignados Pedido[] @relation("ChoferPedidos")

  @@map("chofer")
}

model UserRole {
  id              Int     @id @default(autoincrement())
  clerkUserId     String  @unique @map("clerk_user_id")
  role            String
  idVendedor      Int     @map("id_vendedor")
  nombreEmpresa   String? @map("nombre_empresa")

  @@map("user_role")
}

model ChoferRequest {
  id           Int      @id @default(autoincrement())
  clerkUserId  String   @unique @map("clerk_user_id")
  nombre       String
  telefono     String
  idVendedor   Int      @map("id_vendedor")
  vendorName   String   @map("vendor_name")
  status       String   @default("pending")
  reviewedBy   String?  @map("reviewed_by")
  reviewedAt   DateTime? @map("reviewed_at")
  reason       String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("chofer_request")
}

model AdminDelivery {
  idAdmin     Int    @id @default(autoincrement()) @map("id_admin")
  clerkUserId String @unique @map("clerk_user_id")
  nombre      String
  telefono    String? @map("telefono")

  @@map("admin_delivery")
}

model Pedido {
  idPedido    Int           @id @default(autoincrement())
  estado      String        @default("ready")
  idChoferAsignado Int?     @map("id_chofer_asignado")
  assignedAt  DateTime?     @map("assigned_at")
  updatedAt   DateTime?     @map("updated_at")
  motivoRevision String?    @map("motivo_revision")
  direccion   String
  cliente     String
  telefono    String?
  cantBidones Int
  zona        String
  ruta_pedido ruta_pedido[]

  choferAsignado Chofer? @relation("ChoferPedidos", fields: [idChoferAsignado], references: [idChofer])

  @@map("pedido")
}

model ruta {
  id_ruta     Int           @id @default(autoincrement())
  id_chofer   Int
  id_vendedor Int
  fecha       DateTime
  hora_inicio DateTime?
  hora_fin    DateTime?
  estado      String        @default("pendiente")
  id_zona     Int
  chofer      Chofer        @relation(fields: [id_chofer], references: [idChofer])
  zona        zona          @relation(fields: [id_zona], references: [idZona])
  ruta_pedido ruta_pedido[]
}

model ruta_pedido {
  id_ruta   Int
  id_pedido Int
  pedido    Pedido @relation(fields: [id_pedido], references: [idPedido])
  ruta      ruta   @relation(fields: [id_ruta], references: [id_ruta])

  @@id([id_ruta, id_pedido])
}

model zona {
  idZona Int    @id @default(autoincrement())
  nombre String @unique
  choferes Chofer[]
  ruta   ruta[]
}
