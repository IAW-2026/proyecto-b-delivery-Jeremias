// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Vehiculo {
  idVehiculo       Int      @id @default(autoincrement()) @map("id_vehiculo")
  patente          String
  tipo             String
  capacidadBidones Int      @map("capacidad_bidones")
  idVendedor       Int      @map("id_vendedor")
  choferes         Chofer[]

  @@map("vehiculo")
}

model Chofer {
  idChofer   Int      @id @default(autoincrement()) @map("id_chofer")
  telefono   String
  nombre     String
  estado     String
  idVehiculo Int      @map("id_vehiculo")
  vehiculo   Vehiculo @relation(fields: [idVehiculo], references: [idVehiculo])

  @@map("chofer")
}


