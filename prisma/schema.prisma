// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Vehiculo {
  idVehiculo       Int      @id @default(autoincrement()) @map("id_vehiculo")
  patente          String   @unique
  tipo             String
  capacidadBidones Int      @map("capacidad_bidones")
  idVendedor       Int      @map("id_vendedor")
  choferes         Chofer[]

  @@map("vehiculo")
}

model Chofer {
  idChofer    Int       @id @default(autoincrement()) @map("id_chofer")
  clerkUserId String    @unique @map("clerk_user_id")
  nombre      String    @default("Chofer")
  telefono    String?
  estado      String    @default("pendiente")
  disponible  Boolean   @default(true)
  cbuCvu      String?   @map("cbu_cvu")
  alias       String?
  cuilCuit    String?   @map("cuil_cuit")
  idVendedor  Int       @map("id_vendedor")
  idVehiculo  Int?      @map("id_vehiculo")
  vehiculo    Vehiculo? @relation(fields: [idVehiculo], references: [idVehiculo])

  @@map("chofer")
}

model UserRole {
  id          Int     @id @default(autoincrement())
  clerkUserId String  @unique @map("clerk_user_id")
  role        String
  idVendedor  Int     @map("id_vendedor")
  
  @@map("user_role")
}

model AdminDelivery {
  idAdmin     Int     @id @default(autoincrement()) @map("id_admin")
  clerkUserId String  @unique @map("clerk_user_id")
  nombre      String

  @@map("admin_delivery")
}

model Pedido {
  idPedido    Int      @id @default(autoincrement())
  estado      String   @default("pendiente")  // "pendiente", "ready", "entregado"
  direccion   String
  cliente     String
  telefono    String?
  cantBidones Int
  zona        String   // nombre del barrio

  @@map("pedido")
}